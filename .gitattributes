# Enforce LF line endings for all text files.
# This ensures shell scripts and source files work correctly when checked
# out on Windows and run inside Linux/macOS Docker containers.

* text=auto

# Always LF — scripts and source code must not get CRLF on Windows checkout.
*.sh        text eol=lf
*.go        text eol=lf
*.toml      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.adoc      text eol=lf
*.json      text eol=lf
*.mod       text eol=lf
*.sum       text eol=lf
Makefile    text eol=lf

